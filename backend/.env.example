# ─── DATABASE (Neon) ──────────────────────────────────────────────────────────
# Get BOTH from Neon dashboard → Connection Details
# 1. Toggle "Pooled connection" ON  → copy as DATABASE_URL  (port 6543, has -pooler)
# 2. Toggle "Pooled connection" OFF → copy as DIRECT_URL    (port 5432, no -pooler)
#
# Prisma needs BOTH:
#   DATABASE_URL  = pooled   = used at runtime (fast, handles connection limits)
#   DIRECT_URL    = direct   = used for migrations only
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.eu-west-2.aws.neon.tech/nkenkak?sslmode=require"
DIRECT_URL="postgresql://user:pass@ep-xxx.eu-west-2.aws.neon.tech/nkenkak?sslmode=require"

# ─── AUTH ─────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-minimum-40-characters-long
JWT_REFRESH_SECRET=a-completely-different-40-character-secret-for-refresh-tokens

# ─── SERVER ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ─── EMAIL (optional) ─────────────────────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-gmail-app-password
# EMAIL_FROM=Nkenkak-Ngiesang <noreply@nkenkak-ngiesang.cm>

# ─── CLOUDINARY (optional — photo uploads) ───────────────────────────────────
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ─── PAYMENTS ─────────────────────────────────────────────────────────────────
# Flutterwave — get keys from dashboard.flutterwave.com → Settings → API Keys
# Use TEST keys for development, LIVE keys for production
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
# Webhook secret — set any random string here AND in Flutterwave dashboard
# Dashboard: Settings → Webhooks → Secret Hash
FLW_SECRET_HASH=your-random-webhook-secret

# ─── PAYMENTS (other, optional) ───────────────────────────────────────────────
# MTN_MOMO_API_KEY=
# ORANGE_API_KEY=

# ─── SMS (Twilio, optional) ───────────────────────────────────────────────────
# Sign up at twilio.com → Console → Account Info
# TWILIO_FROM_NUMBER should be a Twilio phone number in E.164 format e.g. +12015551234
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_FROM_NUMBER=+12015551234

# ─── WEB PUSH / PWA ───────────────────────────────────────────────────────────
# Generate: node -e "require('web-push').generateVAPIDKeys()|>console.log"
# Or:       cd backend && node -e "const w=require('web-push');const k=w.generateVAPIDKeys();console.log(JSON.stringify(k))"
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=mailto:admin@nkenkak-ngiesang.cm

# ─── LIVE MEETINGS (Daily.co) ─────────────────────────────────────────────────
# Sign up at daily.co → Dashboard → Developers → API Keys
# DAILY_API_KEY=your_daily_api_key
